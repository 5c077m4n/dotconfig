{
	"$schema": "https://opencode.ai/config.json",
	"permission": {
		"external_directory": "deny",
		"bash": {
			"*": "ask",
			"git log *": "allow",
			"git reflog *": "allow",
			"git add *": "allow",
			"git commit *": "ask",
			"git push *": "deny",
			"grep *": "allow",
			"rg *": "allow",
			"find *": "allow",
			"fd *": "allow",
			"ls *": "allow",
			"cat *": "allow",
			"xxd *": "allow",
			"hexdump *": "allow"
		},
		"read": { "./*": "allow", "./**/.env": "deny", "./**/.env.*": "deny" },
		"edit": { "./*": "allow", "./**/.env": "deny", "./**/.env.*": "deny" }
	}
}
